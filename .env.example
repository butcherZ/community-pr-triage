# --- API Keys ---
LINEAR_API_KEY=lin_api_xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- GitHub ---
GITHUB_REPO=strapi/strapi
GITHUB_ORG=strapi

# --- Linear Team & Project IDs ---
# Find these in Linear team settings or from the URL
LINEAR_TEAM_ID=
LINEAR_CMS_GITHUB_TEAM_ID=
LINEAR_SPRINT_PROJECT_ID=

# --- Linear Status IDs ---
# Find these in Linear: Settings > Teams > <team> > Workflow > click each status
LINEAR_STATUS_TRIAGE=
LINEAR_STATUS_TODO=
LINEAR_STATUS_DONE=
LINEAR_STATUS_CANCELED=

# --- Linear Label IDs (JSON) ---
# PR type labels: GitHub label name -> Linear label ID
LINEAR_LABELS={"pr: fix":"<label-id>","pr: feature":"<label-id>","pr: enhancement":"<label-id>","pr: chore":"<label-id>","pr: doc":"<label-id>"}

# Triage labels (priority, complexity, CI, quick win, has linked issue)
# Example structure:
# {
#   "priority": {"urgent":"<id>","high":"<id>","normal":"<id>","low":"<id>"},
#   "complexity": {"low":"<id>","medium":"<id>","high":"<id>","very_high":"<id>"},
#   "quickWin": "<id>",
#   "hasLinkedIssue": "<id>",
#   "ci": {"passing":"<id>","failing":"<id>","pending":"<id>"}
# }
LINEAR_TRIAGE_LABELS={}

# Source area labels: area name -> Linear label ID
LINEAR_SOURCE_LABELS={}
